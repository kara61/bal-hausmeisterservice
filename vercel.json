{
  "buildCommand": "cd client && npm install && npx vite build",
  "outputDirectory": "client/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/morning", "schedule": "30 4 * * *" },
    { "path": "/api/cron/morning-remind", "schedule": "45 5 * * *" },
    { "path": "/api/cron/checkin-remind", "schedule": "30 6 * * *" },
    { "path": "/api/cron/checkout-remind", "schedule": "30 15 * * *" },
    { "path": "/api/cron/checkout-final", "schedule": "30 17 * * *" },
    { "path": "/api/cron/nightly", "schedule": "0 18 * * *" },
    { "path": "/api/cron/evening-summary", "schedule": "0 18 * * *" },
    { "path": "/api/cron/evening-plan", "schedule": "0 19 * * *" },
    { "path": "/api/cron/auto-approve", "schedule": "0 23 * * *" }
  ]
}
